{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "VerusPDF",
  "outputfilename": "VerusPDF",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "author": {
    "name": "Jonathan Rarey",
    "email": "jonathan.rarey@gmail.com"
  },
  "info": {
    "companyName": "Jonathan Rarey",
    "productName": "VerusPDF",
    "productVersion": "1.0.0",
    "copyright": "Copyright © 2025 Jonathan Rarey",
    "comments": "Free PDF Editor - https://veruspdf.com",
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "Open with VerusPDF",
        "iconName": "appicon",
        "role": "Editor"
      }
    ]
  }
}
