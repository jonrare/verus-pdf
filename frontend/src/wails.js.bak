// wails.js - Wails v2 bridge
// window.go and window.runtime are populated by /wails/ipc.js and /wails/runtime.js
// which are loaded as script tags in index.html and served by Wails' internal server.

function ready(check, timeout = 5000) {
  return new Promise((resolve, reject) => {
    if (check()) return resolve()
    const start = Date.now()
    const id = setInterval(() => {
      if (check()) { clearInterval(id); resolve() }
      else if (Date.now() - start > timeout) { clearInterval(id); reject(new Error('Wails bridge timeout')) }
    }, 20)
  })
}

export async function OpenFileDialog(options = {}) {
  try {
    await ready(() => window.runtime?.OpenFileDialog)
    return await window.runtime.OpenFileDialog(options) ?? ''
  } catch (e) {
    console.error('[Zazel] OpenFileDialog failed:', e)
    return ''
  }
}

export async function SaveFileDialog(options = {}) {
  try {
    await ready(() => window.runtime?.SaveFileDialog)
    return await window.runtime.SaveFileDialog(options) ?? ''
  } catch (e) {
    console.error('[Zazel] SaveFileDialog failed:', e)
    return ''
  }
}

// Viewer
export async function OpenDocument(path) {
  await ready(() => window.go?.viewer?.Service?.OpenDocument)
  return window.go.viewer.Service.OpenDocument(path)
}

